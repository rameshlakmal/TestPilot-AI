# Choose provider: openai or anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Gemini (AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# Server
PORT=3001
MAX_UPLOAD_MB=2

# API security / limits
# Use "*" to allow any origin, or a comma-separated allowlist.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=90

# LLM runtime controls
LLM_TIMEOUT_MS=45000
MAX_TEST_CASES=160

# Jira integration (optional — enables "Import from Jira" in UI)
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=

# AIO (optional)
# AIO_BASE_URL=https://tcms.aiojiraapps.com/aio-tcms
# AIO_TOKEN=
